/*--------------------------------*- C++ -*----------------------------------*\
  Solver settings for aldFoam showerhead simulation
\*---------------------------------------------------------------------------*/
FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      fvSolution;
}

solvers
{
    p
    {
        solver          PCG;
        preconditioner  DIC;
        tolerance       1e-8;
        relTol          0.01;
    }

    pFinal
    {
        $p;
        relTol          0;
    }

    U
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-8;
        relTol          0.1;
    }

    UFinal
    {
        $U;
        relTol          0;
    }

    // Scalar transport (precursor concentration, exposure)
    "(N1|Exp1)"
    {
        solver          PBiCGStab;
        preconditioner  DILU;
        tolerance       1e-10;
        relTol          0.1;
    }

    "(N1|Exp1)Final"
    {
        $N1;
        relTol          0;
    }
}

SIMPLE
{
    nNonOrthogonalCorrectors 1;
    pRefCell            0;
    pRefValue           0;

    residualControl
    {
        p               1e-4;
        U               1e-4;
    }
}

PIMPLE
{
    nOuterCorrectors    2;
    nCorrectors         2;
    nNonOrthogonalCorrectors 1;
    pRefCell            0;
    pRefValue           0;
}

relaxationFactors
{
    fields
    {
        p               0.3;
    }
    equations
    {
        U               0.7;
        N1              0.9;
        Exp1            0.9;
    }
}
